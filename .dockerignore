# Python artefacts
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# Virtual environments
.venv/
.uv/

# Test / coverage artefacts
.pytest_cache/
.mypy_cache/
.ruff_cache/
coverage.xml
htmlcov/
.coverage

# Lambda build output (built inside the container, not needed as input)
lambda_packages/

# Terraform state
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.*
infra/*.tfvars
infra/.terraform.lock.hcl

# Secrets — never in the image
.env
.env.*
!.env.example

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Docs (not needed at runtime)
docs/
